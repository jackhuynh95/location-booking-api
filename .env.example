# Local server
NODE_ENV=development
PORT=3000

# Local PostgreSQL, aligned with docker-compose.yml
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=location_booking
DB_PASSWORD=location_booking
DB_DATABASE=location_booking
DB_SSL=false

# TypeORM runtime behavior
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=true
DB_LOGGING=false

# PostgreSQL connection pool
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000
